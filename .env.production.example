# Production environment for the EC2 deployment.
#
# Put the ENTIRE contents of this file (with real values) into a single GitHub
# Actions secret named APP_ENV. The deploy workflow writes it to /opt/app/.env
# on the instance and appends the ECR_IMAGE line automatically.
#
# Do NOT commit a filled-in version of this file.

# --- LLM ---
# Production on t3.medium (CPU only): use Gemini — Ollama is too slow.
# Local dev with a GPU: LLM_PROVIDER=ollama + OLLAMA_BASE_URL=http://localhost:11434
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
LLM_RATE_PER_MIN=60

# Ollama sidecar (local/GPU hosts only; optional on EC2)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT_SECONDS=300

# --- Hunter.io (contact discovery / email verification) ---
HUNTER_API_KEY=your-hunter-api-key

# --- SMTP (shared fallback mailbox; each user can set their own in Settings) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=you@gmail.com

# --- Auth / security (REQUIRED for multi-user) ---
# Long random string for signing JWTs.
JWT_SECRET=replace-with-a-long-random-string
# Fernet key for encrypting per-user secrets at rest. REQUIRED in production
# (if unset it is derived from JWT_SECRET, which is not recommended).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-a-fernet-key
# Optional bootstrap admin (the first user to register also becomes admin).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Shared-key rate limits + automation defaults ---
LLM_RATE_PER_MIN=60
GEMINI_RATE_PER_MIN=12
HUNTER_RATE_PER_MIN=10
DEFAULT_DAILY_SEND_CAP=20
DEFAULT_PER_DOMAIN_CAP=2
DEFAULT_AUTOMATION_INTERVAL_HOURS=12
DEFAULT_MAX_TAILOR_PER_RUN=5
AUTOMATION_GLOBALLY_ENABLED=true
SCHEDULER_ENABLED=true
SCHEDULER_TICK_MINUTES=30

# --- Persistence (mapped to the /data volume in the container) ---
DATABASE_URL=sqlite:////data/job_hunter.db
UPLOADS_DIR=/data/uploads
GENERATED_DIR=/data/generated

# --- App settings ---
MAX_JOBS_PER_SEARCH=100
MAX_EMAILS_PER_COMPANY=5
JOB_AGE_HOURS=48

# --- Web serving ---
# The app serves the built frontend on the same origin as the API, so CORS is
# only needed if you call the API from another origin. Add your public URL here
# once you attach a domain, comma-separated.
CORS_ORIGINS=https://jobapplicationflow.com,https://www.jobapplicationflow.com,http://localhost:5173

# --- Custom domain via Cloudflare Tunnel (optional) ---
# Only needed if you deploy with docker-compose.cloudflared.yml. Get the token
# from Cloudflare Zero Trust > Networks > Tunnels.
CLOUDFLARE_TUNNEL_TOKEN=

# --- Billing (Stripe) ---
# Create 3 recurring USD Prices (Basic/Standard/Pro) in the Stripe dashboard and
# enable Adaptive Pricing so buyers are charged in their local currency. Add a
# webhook endpoint at https://jobapplicationflow.com/api/webhooks/stripe and copy
# its signing secret here.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_STANDARD=price_...
STRIPE_PRICE_PRO=price_...
# Used for Checkout redirects + the customer portal return URL.
APP_BASE_URL=https://jobapplicationflow.com
TRIAL_DAYS=7

# ECR_IMAGE is appended automatically by the deploy workflow; no need to set it.
