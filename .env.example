# Google Gemini (for CV/cover letter tailoring)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Hunter.io (domain search, email finder, email verification)
HUNTER_API_KEY=your-hunter-api-key

# SMTP (for sending outreach emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# Database
DATABASE_URL=sqlite:///./job_hunter.db

# App settings
MAX_JOBS_PER_SEARCH=100
MAX_EMAILS_PER_COMPANY=5
JOB_AGE_HOURS=48
