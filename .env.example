# --- LLM: local Ollama (default) or cloud Gemini ---
# Local: install Ollama, then `ollama pull llama3.2:3b`
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=300

# Cloud fallback (set LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Hunter.io (domain search, email finder, email verification)
HUNTER_API_KEY=your-hunter-api-key

# SMTP (for sending outreach emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# Database
DATABASE_URL=sqlite:///./job_hunter.db

# App settings
MAX_JOBS_PER_SEARCH=100
MAX_EMAILS_PER_COMPANY=5
JOB_AGE_HOURS=48

# --- Auth / security (multi-user) ---
# Sign JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080
# Fernet key for encrypting per-user secrets (SMTP passwords, key overrides).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, a key is derived from JWT_SECRET (dev only - set this in production).
ENCRYPTION_KEY=
# Optional bootstrap admin created on startup (the first registered user also
# becomes an admin automatically).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Shared-key rate limits (requests/minute across ALL users) ---
LLM_RATE_PER_MIN=60
GEMINI_RATE_PER_MIN=12
HUNTER_RATE_PER_MIN=10

# --- Automation defaults (per new user) + global controls ---
DEFAULT_DAILY_SEND_CAP=20
DEFAULT_PER_DOMAIN_CAP=2
DEFAULT_AUTOMATION_INTERVAL_HOURS=12
DEFAULT_MAX_TAILOR_PER_RUN=5
AUTOMATION_GLOBALLY_ENABLED=true
SCHEDULER_ENABLED=true
SCHEDULER_TICK_MINUTES=30

# --- Billing (Stripe) ---
# Leave blank to run without payments (everyone stays on the free trial / can be
# granted unlimited access by an admin). To enable subscriptions, create 3
# recurring USD Prices in Stripe and enable Adaptive Pricing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PRO=
# Public base URL used for Checkout success/cancel + portal return.
APP_BASE_URL=http://localhost:5173
# Free-trial length granted to new accounts.
TRIAL_DAYS=7

# --- OAuth (optional — social sign-in) ---
# Local redirect URIs to register in Google Cloud / LinkedIn developer consoles:
#   http://localhost:5173/api/auth/google/callback
#   http://localhost:5173/api/auth/linkedin/callback
# Leave OAUTH_FRONTEND_CALLBACK_URL empty to use {APP_BASE_URL}/auth/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
OAUTH_FRONTEND_CALLBACK_URL=
