# Development / staging environment for the dev branch deployment.
#
# Copy to .env.development, fill in real values, then paste the ENTIRE file into
# the GitHub Actions secret: APP_ENV_DEV
#
# Deploys to /opt/app-dev on the same EC2 host (port 8080).
# URL: https://dev.jobapplicationflow.com (add Cloudflare Tunnel route first).

# --- LLM (Gemini recommended on shared CPU host) ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
LLM_RATE_PER_MIN=60

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT_SECONDS=300

# --- Hunter.io (optional — leave empty to use careers@/jobs@ fallbacks) ---
HUNTER_API_KEY=

# --- App SMTP (trial/billing/test emails → users) ---
# Authenticate as the app mailbox; From header uses SYSTEM_EMAIL_FROM.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=email@jobapplicationflow.com
SMTP_PASSWORD=your-app-mailbox-app-password
SMTP_FROM=email@jobapplicationflow.com
SYSTEM_EMAIL_FROM=email@jobapplicationflow.com
SYSTEM_EMAIL_NAME=Job Application Flow

# --- Auth / security (MUST differ from production) ---
JWT_SECRET=replace-with-a-different-dev-jwt-secret
ENCRYPTION_KEY=replace-with-a-different-dev-fernet-key
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Rate limits + automation ---
GEMINI_RATE_PER_MIN=12
HUNTER_RATE_PER_MIN=10
DEFAULT_DAILY_SEND_CAP=20
DEFAULT_PER_DOMAIN_CAP=2
DEFAULT_AUTOMATION_INTERVAL_HOURS=12
DEFAULT_MAX_TAILOR_PER_RUN=5
AUTOMATION_GLOBALLY_ENABLED=true
SCHEDULER_ENABLED=true
SCHEDULER_TICK_MINUTES=30

# --- Persistence (isolated dev volume /data-dev) ---
DATABASE_URL=sqlite:////data/job_hunter_dev.db
UPLOADS_DIR=/data/uploads
GENERATED_DIR=/data/generated

# --- App settings ---
MAX_JOBS_PER_SEARCH=100
MAX_EMAILS_PER_COMPANY=5
JOB_AGE_HOURS=48
CONTACT_EMAIL=you@example.com

# --- Dev domain / CORS ---
CORS_ORIGINS=https://dev.jobapplicationflow.com,http://localhost:5173
APP_BASE_URL=https://dev.jobapplicationflow.com

# --- OAuth (Google + LinkedIn sign-in) ---
# Register these redirect URIs in each provider console:
#   https://dev.jobapplicationflow.com/api/auth/google/callback
#   https://dev.jobapplicationflow.com/api/auth/linkedin/callback
# Leave OAUTH_FRONTEND_CALLBACK_URL empty to use {APP_BASE_URL}/auth/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
OAUTH_FRONTEND_CALLBACK_URL=

# --- Cloudflare Tunnel ---
# Do NOT set CLOUDFLARE_TUNNEL_TOKEN here — prod cloudflared (host network) serves
# dev via a separate public hostname route to http://127.0.0.1:8080

# --- Stripe TEST mode (never use live keys on dev) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_STANDARD=price_...
STRIPE_PRICE_PRO=price_...
TRIAL_DAYS=3
TRIAL_DEFAULT_TIER=basic

# ECR_IMAGE is appended automatically by the deploy workflow.
